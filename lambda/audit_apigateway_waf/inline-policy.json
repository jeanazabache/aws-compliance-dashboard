{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadApiGatewayAndWAF",
      "Effect": "Allow",
      "Action": [
        "apigateway:GET",
        "wafv2:GetWebACLForResource",
        "wafv2:GetWebACL",
        "ec2:DescribeRegions",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "WriteAuditReports",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::utp-aope-reportes-de-auditoria/*"
    }
  ]
}
