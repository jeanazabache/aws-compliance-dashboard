{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAllResourceTags",
      "Effect": "Allow",
      "Action": [
        "tag:GetResources",
        "tag:GetTagKeys",
        "tag:GetTagValues",
        "ec2:DescribeRegions",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "WriteAuditReports",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::utp-aope-reportes-de-auditoria/*"
    }
  ]
}
