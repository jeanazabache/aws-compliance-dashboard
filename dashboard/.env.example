# Configuración de Cognito para el login del dashboard.
# Copia este archivo como `.env` y rellena con los valores de tu User Pool.
# El `.env` está en .gitignore (no se commitea).
#
# Estos valores se incrustan en el bundle JS al hacer `npm run build`.
# Es seguro: el App Client de Cognito es público (sin client secret), igual
# que en cualquier SPA. El login real lo valida Cognito en el servidor.

# ID del User Pool, ej: us-east-1_AbCdEfGhI
VITE_COGNITO_USER_POOL_ID=

# ID del App Client (sin client secret), ej: 1h57kf...e3p
VITE_COGNITO_CLIENT_ID=
